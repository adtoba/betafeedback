# Copy to .env and adjust. Loaded automatically on startup.
ENV=development
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/betafeedback?sslmode=disable
JWT_SECRET=dev-secret-change-me
# When true, the email/start endpoint returns the OTP code in its response
# (handy for local development since no real email is sent).
OTP_DEBUG=true
# Public web origin used to build shareable links (e.g. project invites).
APP_BASE_URL=https://betafeedback.com
# Directory where uploaded feedback attachments (screenshots/recordings) are
# stored and served from. Use a persistent path in production.
MEDIA_DIR=./data/media
# Optional. When set, feedback is classified and structured with the OpenAI API;
# when unset, the backend falls back to local heuristics.
# OPENAI_API_KEY=sk-...
# Optional SMTP for Pro email notifications (logs to stdout when unset).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=BetaFeedback <noreply@betafeedback.com>
